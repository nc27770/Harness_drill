# Copy to .env and fill in real values. .env is git-ignored.
#
# The Anthropic Python SDK reads ANTHROPIC_API_KEY from the environment
# automatically when you call anthropic.Anthropic() with no arguments.
ANTHROPIC_API_KEY=sk-ant-...

# Override the model used by Module 1 (and onward) without editing code.
ANTHROPIC_MODEL=claude-sonnet-4-6
